PORT=3000
SUPABASE_PROJECT_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
BLOB_READ_WRITE_TOKEN=vercel_blob_read_write_token
ON_LINE_PROCESS=false
GEMINI_API_KEY=your-gemini-api-key

# Email provider: gmail, resend, mailgun, mailjet, mailersend, or zoho
# For Render free services, use an HTTP API provider such as resend/mailgun/mailjet.
EMAIL_PROVIDER=gmail
GMAIL_EMAIL=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
GMAIL_FROM_NAME=Notification
GMAIL_SMTP_FORCE_IPV4=true
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=sender@your-verified-domain
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-mailgun-domain
MAILGUN_FROM_EMAIL=sender@your-mailgun-domain
MAILGUN_BASE_URL=https://api.mailgun.net


# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://postgres.vbgqvlmrkctbodiudfkc:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://postgres.vbgqvlmrkctbodiudfkc:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"
